# Copy this file to .env and fill in your values.
# All three variables are required — the container will refuse to start without them.

# Sync API token — shared secret between the frontend and sync server.
# Generate with: openssl rand -hex 32
SYNC_TOKEN=replace-with-your-secret-token

# HTTP Basic Auth credentials — gates the entire website so only you can access it.
# This prevents random visitors from seeing your SYNC_TOKEN via /env.js.
# Choose any username and a strong password.
NGINX_USER=replace-with-your-username
NGINX_PASSWORD=replace-with-a-strong-password
